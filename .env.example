# Host address is required (e.g., localhost or 127.0.0.1)
DB_HOST=127.0.0.1

# Port must be between 1 and 65535
DB_PORT=5432

# Database username is required
DB_USERNAME=postgres

# Database password cannot be empty
DB_PASSWORD=your_database_password

# Database name is required
DB_DATABASE=finman_db

# Security risk: JWT_SECRET must be at least 32 characters long
# Avoid using common words like 'secret' or 'password'
JWT_SECRET=your_super_secret_key_at_least_32_characters_long

# Must be a valid URL. Defaults to 'http://localhost:3000'
NEXT_PUBLIC_API_URL=http://localhost:3000
